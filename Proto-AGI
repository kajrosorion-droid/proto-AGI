PHI = 1.618033988749895

_phi_cache = {}
def phi_hash_cached(x, y, seed):
    key = (x, y, seed)
    if key not in _phi_cache:
        _phi_cache[key] = ((x * PHI + y * PHI**2 + seed * PHI**3) % 1.0)
    return _phi_cache[key]

def phi_hash(x, y, seed=0):
    return ((x * PHI + y * PHI**2 + seed * PHI**3) % 1.0)

def phi_noise(t, x, y, seed=0):
    return (phi_hash(t + x, y + t, seed) - 0.5) * 0.1

def squash(x):
    if np.isnan(x) or np.isinf(x):
        return 0.5
    return x / (1.0 + abs(x))

def safe_mean(arr, default=0.0):
    arr = np.asarray(arr)
    mask = np.isfinite(arr)
    if not np.any(mask):
        return default
    return float(np.mean(arr[mask]))

def safe_std(arr, default=0.0):
    arr = np.asarray(arr)
    mask = np.isfinite(arr)
    if np.sum(mask) < 2:
        return default
    return float(np.std(arr[mask]))

