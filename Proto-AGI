def diffuse(field):
    field = np.nan_to_num(field, nan=0.0)
    kernel = 0.2
    padded = np.pad(field, ((1,1),(1,1),(0,0)), mode='wrap')
    out = np.copy(field)
    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            out[x,y] = (field[x,y] * (1 - kernel) +
                       padded[x+1,y, :] * kernel * 0.25 +
                       padded[x-1,y, :] * kernel * 0.25 +
                       padded[x,y+1, :] * kernel * 0.25 +
                       padded[x,y-1, :] * kernel * 0.25)
    out[:,:,CH['energy']] *= GLOBAL_VISCOSITY
    out[:,:,CH['vorticity']] *= VORTICITY_DECAY
    return out

def update_scar(field, scar):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    delta = energy - np.mean(energy)
    scar = 0.98 * scar + 0.02 * np.tanh(np.abs(delta))
    return scar

def apply_scar_feedback(field, scar):
    field[:,:,CH['energy']] += SCAR_ENERGY_COUPLING * np.tanh(np.nan_to_num(scar, nan=0.0))
    field[:,:,CH['energy']] -= LOCAL_FATIGUE * field[:,:,CH['energy']] * np.abs(np.nan_to_num(scar, nan=0.0))
    field[:,:,CH['energy']] *= 0.999
    field[:,:,CH['vorticity']] += 0.001 * (np.nan_to_num(scar, nan=0.0) - np.mean(np.nan_to_num(scar, nan=0.0)))
    return field

def heartbeat_injection(field, t):
    raw = (t * PHI * HEARTBEAT_FREQ) % 1.0
    cx = int(raw * (WORLD_SIZE-1))
    cy = int(((raw * PHI) % 1.0) * (WORLD_SIZE-1))
    for dx in [-1, 0, 1]:
        for dy in [-1, 0, 1]:
            nx, ny = (cx+dx)%WORLD_SIZE, (cy+dy)%WORLD_SIZE
            field[nx, ny, CH['energy']] += HEARTBEAT_AMPLITUDE * (1 - 0.3*(abs(dx)+abs(dy)))
    return field

def apply_crisis(field, t):
    if t % CRISIS_PERIOD == 0 and t > 0:
        shock = np.fromfunction(lambda x, y: phi_noise(t+5000, x, y), (WORLD_SIZE, WORLD_SIZE))
        field[:,:,CH['energy']] += CRISIS_INTENSITY * shock
    return field

