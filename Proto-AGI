def _spawn_if_needed(field, patterns, next_id_counter, t, current_phase):
    if len(patterns) < MIN_POPULATION_FOR_SPAWN and current_phase == "EXPLORE":
        spawn_count = max(1, (MIN_POPULATION_FOR_SPAWN - len(patterns)) // 2)
        for _ in range(spawn_count):
            x = int(phi_hash(t, _, 100) * WORLD_SIZE)
            y = int(phi_hash(t, _, 101) * WORLD_SIZE)
            if field[x, y, CH['owner']] == 0:
                pid = next_id_counter
                next_id_counter += 1
                p = Pattern(pid, {(x, y)})
                patterns.append(p)
    return next_id_counter

def _resolve_competitions(field, patterns, current_phase):
    alive = [p for p in patterns if p.alive]
    for i, p1 in enumerate(alive):
        for p2 in alive[i+1:]:
            if p1.cells & p2.cells:
                p1.compete(p2, field, current_phase)

def _apply_divisions(field, patterns, next_id_counter):
    newborns = []
    for p in patterns:
        if p.can_divide():
            child = p.divide(field, next_id_counter)
            if child:
                newborns.append(child)
                next_id_counter += 1
    patterns.extend(newborns)
    return next_id_counter

def _process_death(field, p):
    for (x, y) in p.cells:
        field[x, y, CH['scar']] += 0.1 * max(p.compression, 0)
        field[x, y, CH['owner']] = 0
        field[x, y, CH['crisis']] += p.crisis_memory * 0.5
        field[x, y, CH['binding']] += p.unresolved_contradiction * 1.2
    store_echo(p)
    p.alive = False

def evolution_step(field, patterns, next_id_counter, t, global_hunger=1.0,
                   stabilization_active=False, recovery_active=False, crisis_level=0,
                   boredom_score=0.0, current_phase="MODEL"):
    next_id_counter = _spawn_if_needed(field, patterns, next_id_counter, t, current_phase)

    if boredom_score > 0.4 and patterns:
        for p in patterns:
            if p.alive and phi_hash(p.id, t, 500) < 0.2:
                p.apply_given_operator(field, forced=True)

    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            if (np.isfinite(field[x, y, CH['unknown']]) and
                field[x, y, CH['unknown']] > UNKNOWN_SPAWN_THRESHOLD and
                field[x, y, CH['owner']] == 0):
                if phi_hash(x, y, t) < UNKNOWN_SPAWN_PROB:
                    pid = next_id_counter
                    next_id_counter += 1
                    patterns.append(Pattern(pid, {(x, y)}))

    for p in patterns:
        p.update_model(field, current_phase)
    for p in patterns:
        p.grow(field)

    _resolve_competitions(field, patterns, current_phase)
    next_id_counter = _apply_divisions(field, patterns, next_id_counter)

    for p in patterns:
        p.metabolic_tax(field, hunger_mult=global_hunger)
        p.update_properties(field)
        if p.should_die():
            _process_death(field, p)
        if p.given_trigger:
            for (x, y) in p.cells:
                field[x, y, CH['unknown']] = min(field[x, y, CH['unknown']] + 0.05, 0.8)
                field[x, y, CH['crisis']] = min(field[x, y, CH['crisis']] + 0.1, 1.0)
                field[x, y, CH['binding']] = min(1.0, field[x, y, CH['binding']] + 0.1)

    if stabilization_active:
        for p in patterns:
            p.model *= STAB_MODEL_GROWTH
            p.self_model *= STAB_MODEL_GROWTH
            p.pred_error *= STAB_ERROR_DECAY
            p.unknown_error *= STAB_ERROR_DECAY

    if recovery_active:
        for p in patterns:
            p.model += RECOVERY_MODEL_PULL * (p.prediction - p.model)
            p.self_model += RECOVERY_MODEL_PULL * (p.self_state_prediction - p.self_model)

    if t % LINEAGE_SELECTION_INTERVAL == 0:
        patterns = lineage_selection(patterns)

    field[:,:,CH['owner']] = 0
    field[:,:,CH['surprise']] *= SURPRISE_DECAY

    div_map = np.zeros((WORLD_SIZE, WORLD_SIZE))
    for p in patterns:
        for (x, y) in p.cells:
            div_map[x, y] += float(np.linalg.norm(p.model - p.prediction))
    max_div = np.max(div_map)
    if max_div > 0 and np.isfinite(max_div):
        div_map = div_map / max_div

    field[:,:,CH['unknown']] = (0.7 * field[:,:,CH['unknown']] * UNKNOWN_DECAY +
                                UNKNOWN_DIVERGENCE_WEIGHT * div_map + UNKNOWN_BACKGROUND)
    field[:,:,CH['unknown']] = np.clip(field[:,:,CH['unknown']], 0, 0.8)
    field[:,:,CH['crisis']] *= CRISIS_MEMORY_DECAY
    field[:,:,CH['event']] *= 0.9
    field[:,:,CH['btype']] *= 0.9
    field[:,:,CH['binding']] *= 0.975

    survivors = []
    for p in patterns:
        if p.alive:
            survivors.append(p)
            for (x, y) in p.cells:
                field[x, y, CH['owner']] = p.id
                field[x, y, CH['surprise']] = p.pred_error
                explained = p.unknown_prediction * 0.05 * (p.confidence ** 0.5)
                field[x, y, CH['unknown']] = max(UNKNOWN_BACKGROUND, field[x, y, CH['unknown']] - explained)
                field[x, y, CH['crisis']] += p.crisis_memory * 0.01
                field[x, y, CH['binding']] += 0.01 * p.unresolved_contradiction
                field[x, y, :5] += 0.001 * (p.model - field[x, y, :5])
    return survivors, next_id_counter

