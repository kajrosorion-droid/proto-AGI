def init_field():
    F = np.zeros((WORLD_SIZE, WORLD_SIZE, CHANNELS))
    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            F[x, y, CH['energy']] = phi_hash(x, y, 1) * 0.2 - 0.1
            F[x, y, CH['flux']] = phi_hash(x, y, 2) * 0.1
            F[x, y, CH['scar']] = 0.0
            F[x, y, CH['noise']] = 0.0
            F[x, y, CH['vorticity']] = phi_hash(x, y, 3) * 0.1 - 0.05
            F[x, y, CH['owner']] = 0.0
            F[x, y, CH['surprise']] = 0.0
            F[x, y, CH['unknown']] = UNKNOWN_BACKGROUND
            F[x, y, CH['event']] = 0.0
            F[x, y, CH['btype']] = 0.0
            F[x, y, CH['crisis']] = 0.0
            F[x, y, CH['binding']] = 0.05
    return F

def init_scar():
    return np.zeros((WORLD_SIZE, WORLD_SIZE))

def init_agents():
    agents = []
    cols = int(np.ceil(np.sqrt(AGENT_COUNT)))
    rows = int(np.ceil(AGENT_COUNT / cols))
    for i in range(AGENT_COUNT):
        row = i // cols
        col = i % cols
        x = col * (WORLD_SIZE // cols) + (WORLD_SIZE // (2*cols))
        y = row * (WORLD_SIZE // rows) + (WORLD_SIZE // (2*rows))
        x = min(max(x, 0), WORLD_SIZE-1)
        y = min(max(y, 0), WORLD_SIZE-1)
        agents.append({
            "pos": np.array([x, y]),
            "memory": np.zeros(8),
            "drift": np.array([phi_hash(i, 0, 10) - 0.5, phi_hash(i, 1, 10) - 0.5]) * 0.1
        })
    return agents

def match_patterns(new_components, old_patterns, field):
    matched = set()
    updated_patterns = []
    for cells in new_components:
        best_p = None
        best_overlap = 0
        for p in old_patterns:
            if not p.alive or p.id in matched: continue
            overlap = len(cells & p.cells)
            if overlap > best_overlap:
                best_overlap = overlap
                best_p = p
        if best_p and best_overlap > len(cells) * 0.3:
            best_p.cells = cells
            best_p.update_properties(field)
            best_p.update_model(field)
            best_p.age += 1
            updated_patterns.append(best_p)
            matched.add(best_p.id)
        else:
            pid = max([p.id for p in old_patterns] + [1000]) + 1
            p = Pattern(pid, cells)
            p.update_properties(field)
            p.update_model(field)
            updated_patterns.append(p)
    for p in old_patterns:
        if p.alive and p.id not in matched:
            p.alive = False
    return updated_patterns

def detect_new_components(field):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    mask = energy > PATTERN_ENERGY_THRESHOLD
    labeled, num = label(mask)
    slices = find_objects(labeled)
    components = []
    for i, slc in enumerate(slices, 1):
        if slc is None: continue
        region = labeled[slc] == i
        cells = set()
        for dx in range(slc[0].start, slc[0].stop):
            for dy in range(slc[1].start, slc[1].stop):
                if region[dx-slc[0].start, dy-slc[1].start]:
                    cells.add((dx, dy))
        if cells: components.append(cells)
    return components

def lineage_selection(patterns):
    if len(patterns) <= MAX_LINEAGES: return patterns
    lineage_ages = {}
    for p in patterns:
        lid = p.lineage_id
        if lid not in lineage_ages:
            lineage_ages[lid] = p.lineage_age
        else:
            lineage_ages[lid] = min(lineage_ages[lid], p.lineage_age)
    
    lineage_scores = {}
    for p in patterns:
        lid = p.lineage_id
        lineage_scores[lid] = lineage_scores.get(lid, 0) + max(p.fitness, 0)
    strong = sorted(lineage_scores.items(), key=lambda x: x[1], reverse=True)
    allowed = set()
    for lid, _ in strong:
        if len(allowed) >= MAX_LINEAGES:
            break
        if lineage_ages.get(lid, 0) < LINEAGE_MIN_AGE:
            allowed.add(lid)
            continue
        allowed.add(lid)
    return [p for p in patterns if p.lineage_id in allowed]

def ecosystem_pressure(field):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    avg = np.mean(energy)
    field[:,:,CH['energy']] += 0.002 * (avg - energy)
    field[:,:,CH['flux']] += 0.001 * (np.roll(energy, 1, axis=0) - energy)
    field[:,:,CH['flux']] += 0.001 * (np.roll(energy, -1, axis=1) - energy)
    return field

