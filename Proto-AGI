echo_prison = []

def store_echo(pattern):
    echo = {
        'identity': pattern.identity.copy(),
        'model': pattern.model.copy(),
        'unresolved_contradiction': float(pattern.unresolved_contradiction) * 1.2,
        'role': pattern.role,
        'age': 0
    }
    echo_prison.append(echo)

def inject_echo(field, patterns, t, scar):
    global echo_prison
    if not echo_prison or len(patterns) == 0:
        return
    boredom = calculate_boredom(patterns, field)

    if len(echo_prison) >= 2 and phi_hash(t, 0, 3333) < 0.1:
        i1 = int(phi_hash(t, 1, 4444) * len(echo_prison))
        i2 = int(phi_hash(t, 2, 5555) * len(echo_prison))
        if i1 != i2:
            e1 = echo_prison[i1]
            e2 = echo_prison[i2]
            if abs(e1['unresolved_contradiction'] - e2['unresolved_contradiction']) <= 0.25:
                new_model = (e1['model'] + e2['model']) / 2.0
                new_model += np.array([phi_hash(t, i, 8888) - 0.5 for i in range(5)]) * 0.01
                new_unresolved = (e1['unresolved_contradiction'] + e2['unresolved_contradiction']) / 2.0
                new_role = e1['role'] if phi_hash(t, 3, 6666) < 0.5 else e2['role']
                new_echo = {
                    'identity': e1['identity'],
                    'model': new_model,
                    'unresolved_contradiction': float(new_unresolved),
                    'role': new_role,
                    'age': 0
                }
                echo_prison.append(new_echo)
                print(f"[t={t}] Echo recombination: blending {i1} and {i2}, unresolved={new_unresolved:.3f}")

    prob = min(0.25, len(echo_prison) * 0.03 + boredom * 0.12)
    if phi_hash(t, 0, 999) < prob:
        candidates = [e for e in echo_prison if e['age'] > 3]
        if not candidates:
            candidates = echo_prison
        echo = candidates[int(phi_hash(t, 1, 1001) * len(candidates)) % len(candidates)]
        seed = int(phi_hash(t, 2, 1002) * WORLD_SIZE * WORLD_SIZE)
        x = seed % WORLD_SIZE
        y = (seed // WORLD_SIZE) % WORLD_SIZE
        field[x, y, CH['energy']] += 0.12
        field[x, y, CH['unknown']] = min(0.8, field[x, y, CH['unknown']] + 0.2)
        field[x, y, CH['binding']] += 0.35
        echo['unresolved_contradiction'] = float(echo['unresolved_contradiction']) * 0.88
        echo['age'] = 0
        if float(echo['unresolved_contradiction']) < 0.02:
            echo_prison.remove(echo)
        print(f"[t={t}] Echo injected at ({x},{y}), role={echo['role']}, unresolved={float(echo['unresolved_contradiction']):.3f}")

    for p in patterns:
        if p.alive and p.unresolved_contradiction > 0.2:
            local_scar = safe_mean([scar[c[0], c[1]] for c in p.cells], 0)
            p.soul_weight += 0.01 * local_scar

    for e in echo_prison:
        e['age'] += 1

    if len(echo_prison) > 40 and phi_hash(t, len(echo_prison), 9999) < 0.1:
        idx = int(phi_hash(t, 9998, 9997) * len(echo_prison)) % len(echo_prison)
        echo_prison.pop(idx)

