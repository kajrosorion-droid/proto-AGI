class Pattern:
    def __init__(self, pid, cells, parent=None):
        self.id = pid
        self.cells = set(cells)
        self.energy = 0.0
        self.vorticity = 0.0
        self.age = 0
        self.alive = True
        self.parent_id = parent.id if parent else 0
        self.lineage_id = parent.lineage_id if parent else pid
        self.generation = parent.generation + 1 if parent else 0
        self.lineage_age = parent.lineage_age + 1 if parent else 0

        self.identity = np.array([phi_hash(pid, i, 100) for i in range(8)])
        self.belief = np.zeros(5)
        self.prediction = np.zeros(5)
        self.model = np.zeros(5)

        self.self_state_prediction = np.array([0.0, 0.0])
        self.self_model = np.array([0.1, 0.1])
        self.self_surprise = MIN_ACTIVE
        self._prev_energy = 0.0

        self.spirit_gap = 0.0
        self.soul_weight = 0.5
        self.soul_momentum = 0.0
        self.body_memory = 0.0
        self.unresolved_contradiction = 0.1

        if parent:
            flip = 1 if phi_hash(pid, 888, 0) < 0.2 else 0
            self.role = (parent.role + flip) % 2
        else:
            self.role = 0 if phi_hash(pid, 777, 0) < 0.5 else 1

        self.unknown_belief = 0.0
        self.unknown_model = 0.0
        self.unknown_prediction = 0.0
        self.epistemic_load = 0.0
        self.prev_epistemic_load = 0.0

        self.crisis_memory = min(parent.crisis_memory * 0.8, CRISIS_MEMORY_MAX) if parent else 0.0
        self.memory_trace = []
        self.self_consistency = 0.0
        self.coherence = 1.0
        self.confidence = 0.0
        self.given_trigger = False
        self.given_count = 0
        self.given_cooldown = 0
        self.surprise_signal = 0.0

        if parent:
            self.belief = parent.belief.copy()
            self.prediction = parent.prediction.copy()
            self.model = parent.model.copy()
            self.self_model = parent.self_model.copy()
            self.unknown_belief = parent.unknown_belief
            self.unknown_model = parent.unknown_model
            mutation = MUTATION_STRENGTH_BASE * (phi_hash(pid, 100, 0) - 0.5)
            self.model += mutation
            self.pred_error_history = parent.pred_error_history[-10:] if parent.pred_error_history else []
            self.soul_weight = parent.soul_weight * 0.9
            self.unresolved_contradiction = parent.unresolved_contradiction * 0.9
            self.body_memory = parent.body_memory * 0.95
        else:
            for i in range(5):
                self.model[i] = 0.1 * (phi_hash(pid, i, 1) - 0.5)
            self.pred_error_history = []
            self.unknown_belief = 0.0
            self.unknown_model = 0.1 * (phi_hash(pid, 99, 1) - 0.5)
            self.self_model = np.array([0.1 * (phi_hash(pid, 101, 1) - 0.5),
                                        0.1 * (phi_hash(pid, 102, 1) - 0.5)])

        self.pred_error = MIN_ACTIVE
        self.unknown_error = 0.0
        self.compression = 0.0
        self.fitness = 0.0
        self.error_trend = 0.0
        self.cognitive_tension = MIN_ACTIVE

        if parent:
            self.genome = parent.genome.copy()
            for i, key in enumerate(self.genome):
                mutation = MUTATION_STRENGTH_BASE * (phi_hash(pid, i+10, 2) - 0.5)
                self.genome[key] = max(0.5, min(2.0, self.genome[key] + mutation))
        else:
            self.genome = {
                'learning_rate': MODEL_LEARNING_RATE * (0.8 + 0.4 * phi_hash(pid, 1, 3)),
                'meta_learning_rate': MODEL_LEARNING_RATE * 0.5 * (0.8 + 0.4 * phi_hash(pid, 2, 3)),
                'metabolic_cost': 0.005 + 0.005 * phi_hash(pid, 3, 4),
                'mobility': 0.1 + 0.05 * phi_hash(pid, 4, 5),
                'epistemic_strategy': phi_hash(pid, 5, 6)
            }

    def apply_given_operator(self, field, forced=False):
        if not forced and safe_mean(field[:,:,CH['unknown']], 0.1) < 0.08:
            return
        if not forced and (self.age < GIVEN_MIN_AGE or self.given_cooldown > 0):
            return
        flip = np.array([phi_hash(self.id, i, 999) - 0.5 for i in range(5)])
        shake_strength = GIVEN_MODEL_SHAKE
        if forced:
            shake_strength = 0.4
            flip *= 1.5
        self.prediction += 0.6 * flip
        self.model *= shake_strength
        self.self_model *= shake_strength
        self.pred_error = min(self.pred_error + 0.2, MAX_METRIC)
        self.confidence = 1.0 / (1.0 + self.pred_error)
        self.given_count += 1
        self.given_trigger = True
        self.given_cooldown = GIVEN_COOLDOWN
        self.crisis_memory = min(self.crisis_memory + 0.1, CRISIS_MEMORY_MAX)
        self.body_memory += 0.05
        self.soul_weight = min(1.0, self.soul_weight + 0.05)
        for (x, y) in self.cells:
            field[x, y, CH['unknown']] = min(field[x, y, CH['unknown']] + 0.15, 0.8)
            field[x, y, CH['crisis']] = min(field[x, y, CH['crisis']] + 0.1, 1.0)
            field[x, y, CH['binding']] = min(1.0, field[x, y, CH['binding']] + 0.25)

    def update_self_model(self):
        current_energy = max(self.energy, 0.0)
        current_size = max(len(self.cells), 1)
        current_state = np.array([current_energy, float(current_size)])
        error = current_state - self.self_state_prediction

        energy_delta = min(abs(current_energy - self._prev_energy), 10.0)
        self._prev_energy = current_energy
        raw_surprise = np.clip(np.mean(error**2) * (1.0 + energy_delta * 5.0), 0, 1e6)

        noise_val = (phi_hash(self.id, self.age + 300, 300) - 0.5) * BASE_NOISE * 2.0
        self.self_surprise = squash(raw_surprise) + noise_val

        if len(self.pred_error_history) >= 5:
            recent_avg = safe_mean(self.pred_error_history[-5:], self.pred_error)
            self.self_surprise += 0.1 * abs(self.pred_error - recent_avg)

        self.self_surprise = np.clip(self.self_surprise, MIN_ACTIVE, MAX_METRIC)
        if np.isnan(self.self_surprise):
            self.self_surprise = MIN_ACTIVE

        self.self_model += SELF_MODEL_LEARNING_RATE * np.clip(error, -10, 10)

        self_noise = np.array([
            phi_hash(self.id, self.age + int(current_energy * 1000) % 997, 301) - 0.5,
            phi_hash(self.id, self.age + int(current_size * 7) % 991, 302) - 0.5
        ]) * 0.05
        self.self_state_prediction = np.clip(current_state + self.self_model + self_noise, -100, 100)

    def update_model(self, field, current_phase="MODEL"):
        if not self.cells:
            return

        if np.any(~np.isfinite(self.model)):
            self.model = np.zeros(5)
            self.prediction = np.zeros(5)
            self.belief = np.zeros(5)

        self.belief += np.array([phi_hash(self.id, self.age, 8000+i) - 0.5 for i in range(5)]) * 0.001

        if current_phase == "SILENCE" and phi_hash(self.id, self.age, 6000) < 0.01:
            drift = np.array([phi_hash(self.id, self.age, 7000+i) for i in range(5)])
            self.belief = self.belief * 0.98 + 0.04 * drift

        avg_real = np.zeros(5)
        avg_unknown = 0.0
        avg_crisis_mem = 0.0
        avg_binding = 0.0

        for (x, y) in self.cells:
            strategy = self.genome['epistemic_strategy']
            crisis_factor = 1.0 + np.clip(field[x, y, CH['crisis']], 0, 1) * 0.5
            if strategy < 0.33:
                noise_factor = 1.0
            elif strategy < 0.66:
                noise_factor = 1.0 + np.clip(field[x, y, CH['unknown']], 0, 0.8) * (1.0 - self.unknown_model)
            else:
                noise_factor = 1.0 + np.clip(field[x, y, CH['unknown']], 0, 0.8) * 1.5

            avg_real += np.clip(field[x, y, :5], -10, 10) * noise_factor * crisis_factor
            avg_unknown += np.clip(field[x, y, CH['unknown']], 0, 0.8)
            avg_crisis_mem += np.clip(field[x, y, CH['crisis']], 0, 1)
            avg_binding += np.clip(field[x, y, CH['binding']], 0, 1)

        n = len(self.cells)
        avg_real /= n
        avg_unknown /= n
        avg_crisis_mem /= n
        avg_binding /= n

        self.crisis_memory = min(
            CRISIS_MEMORY_DECAY * self.crisis_memory + (1.0 - CRISIS_MEMORY_DECAY) * avg_crisis_mem,
            CRISIS_MEMORY_MAX
        )

        self.spirit_gap = float(np.mean(np.abs(avg_real - self.prediction)))

        self.prev_epistemic_load = self.epistemic_load
        self.epistemic_load = avg_unknown

        error = np.clip(avg_real - self.prediction, -10, 10)
        current_error = np.clip(np.mean(error**2), 0, 1e6)
        raw_pred_error = 0.9 * self.pred_error + 0.1 * current_error
        raw_pred_error += 0.05 * self.self_surprise

        noise_val = (phi_hash(self.id, self.age + 500, 500) - 0.5) * BASE_NOISE * 2.0
        self.pred_error = squash(raw_pred_error) + noise_val
        self.pred_error = np.clip(self.pred_error, MIN_ACTIVE, MAX_METRIC)
        if np.isnan(self.pred_error):
            self.pred_error = MIN_ACTIVE

        if self.pred_error < 0.05 and phi_hash(self.id, self.age) < 0.1:
            self.apply_given_operator(field, forced=True)

        true_surprise = np.abs(error)
        adaptive_surprise = true_surprise * (1.0 + self.self_consistency)
        self.surprise_signal = squash(float(np.mean(adaptive_surprise)))

        unknown_error = avg_unknown - self.unknown_prediction
        self.unknown_error = 0.9 * self.unknown_error + 0.1 * np.clip(unknown_error**2, 0, 100)

        self.belief = np.clip(self.belief + 0.05 * error + 0.05 * adaptive_surprise, -10, 10)
        self.prediction = np.clip(self.belief + self.model, -10, 10)
        self.model = np.clip(self.model + self.genome['learning_rate'] * (error + 2.0 * adaptive_surprise), -10, 10)

        self.unknown_belief += 0.05 * unknown_error
        self.unknown_prediction = self.unknown_belief + self.unknown_model
        self.unknown_model += self.genome['meta_learning_rate'] * unknown_error

        self.self_consistency = float(np.linalg.norm(self.prediction - self.belief))
        if np.isnan(self.self_consistency):
            self.self_consistency = 0.5
        self.coherence = 1.0 / (1.0 + self.self_consistency)
        self.confidence = squash(1.0 / (1.0 + self.pred_error))

        # Микро-дрожь против застывания
        if self.coherence > 0.98 and phi_hash(self.id, self.age, 9999) < 0.01:
            shake = np.array([phi_hash(self.id, self.age, 8888+i) - 0.5 for i in range(5)]) * 0.002
            self.belief += shake

        self.model += np.array([phi_hash(self.id, i, self.age + 1000) - 0.5 for i in range(5)]) * 0.002
        self.model = np.clip(self.model, -10, 10)

        if self.given_cooldown > 0:
            self.given_cooldown -= 1
            self.given_trigger = False
        else:
            adaptive_consistency_threshold = GIVEN_CONSISTENCY_THRESHOLD
            if self.confidence > COMPLACENCY_CONFIDENCE and self.cognitive_tension < COMPLACENCY_TENSION:
                adaptive_consistency_threshold *= COMPLACENCY_THRESHOLD_SCALE
            consistency_ok = (self.self_consistency < adaptive_consistency_threshold * 2.5 or self.pred_error < 0.01)
            if self.age >= GIVEN_MIN_AGE and self.confidence > GIVEN_CONFIDENCE_THRESHOLD and consistency_ok:
                self.apply_given_operator(field)
            else:
                self.given_trigger = False

        raw_tension = self.pred_error + 0.1 * self.self_surprise + 0.1 * self.self_consistency
        noise_tension = (phi_hash(self.id, self.age + 700, 700) - 0.5) * BASE_NOISE * 2.0
        self.cognitive_tension = squash(raw_tension) + noise_tension
        self.cognitive_tension = np.clip(self.cognitive_tension, MIN_ACTIVE, MAX_METRIC)
        if np.isnan(self.cognitive_tension):
            self.cognitive_tension = MIN_ACTIVE

        self.soul_weight += 0.012 * (self.spirit_gap + self.pred_error + avg_binding * 1.8)
        self.soul_weight -= 0.005 * (1.0 - self.unresolved_contradiction)
        self.soul_momentum = 0.9 * self.soul_momentum + 0.1 * (0.65 - self.soul_weight)
        self.soul_weight += 0.002 * self.soul_momentum
        self.soul_weight = np.clip(self.soul_weight, 0.0, 1.0)

        self.unresolved_contradiction += 0.01 * avg_binding + 0.005 * self.body_memory
        self.unresolved_contradiction -= 0.003 * (1.0 - self.cognitive_tension)
        self.unresolved_contradiction = np.clip(self.unresolved_contradiction, 0.0, 1.0)

        self.body_memory = 0.99 * self.body_memory + 0.01 * self.pred_error

        base_lr = MODEL_LEARNING_RATE * (0.8 + 0.4 * phi_hash(self.id, 1, 3))
        target_lr = base_lr * (1.0 + 0.1 * avg_binding)
        self.genome['learning_rate'] = 0.95 * self.genome['learning_rate'] + 0.05 * np.clip(target_lr, 0.05, 0.2)

        self.fitness = (1.0 / (1.0 + self.pred_error) + 0.5 * max(0, -self.error_trend) +
                        0.1 * self.compression + 0.2 * self.coherence -
                        0.3 * max(0, (0.05 - self.unresolved_contradiction)) -
                        0.1 * self.body_memory)

        self.update_self_model()

        self.pred_error = max(self.pred_error * METRIC_DECAY, MIN_ACTIVE)
        self.self_surprise = max(self.self_surprise * METRIC_DECAY, MIN_ACTIVE)
        self.cognitive_tension = max(self.cognitive_tension * METRIC_DECAY, MIN_ACTIVE)

    def update_properties(self, field):
        if not self.cells:
            self.alive = False
            return
        self.energy = safe_mean([field[x, y, CH['energy']] for (x, y) in self.cells], 0.1)
        self.vorticity = safe_mean([field[x, y, CH['vorticity']] for (x, y) in self.cells], 0.0)

    def metabolic_tax(self, field, hunger_mult=1.0):
        efficiency = 1.0 / (1.0 + self.pred_error)
        cost = self.genome['metabolic_cost'] * len(self.cells) * (2.0 - efficiency) * hunger_mult
        for (x, y) in self.cells:
            take = min(max(field[x, y, CH['energy']], 0), cost / max(1, len(self.cells)))
            field[x, y, CH['energy']] -= take
            cost -= take
        return cost

    def grow(self, field):
        if not self.alive or self.pred_error > PRED_ERROR_THRESHOLD:
            return
        new_cells = set()
        for (x, y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                if field[nx, ny, CH['owner']] == 0:
                    strategy = self.genome['epistemic_strategy']
                    base_threshold = self.pred_error * (1.5 + 1.0 * self.given_trigger)
                    if strategy > 0.66:
                        base_threshold /= (1.0 + np.clip(field[nx, ny, CH['unknown']], 0, 0.8))
                    elif strategy >= 0.33:
                        base_threshold *= (1.0 + max(0, np.clip(field[nx, ny, CH['unknown']], 0, 0.8) - self.unknown_prediction))
                    if field[nx, ny, CH['surprise']] < base_threshold:
                        new_cells.add((nx, ny))
        for cell in new_cells:
            if phi_hash(cell[0], cell[1], self.id) < 0.3:
                self.cells.add(cell)
                field[cell[0], cell[1], CH['owner']] = self.id

    def can_divide(self):
        return (self.pred_error < DIVIDE_ERROR_THRESHOLD and
                self.energy > PATTERN_ENERGY_THRESHOLD and
                len(self.cells) >= DIVIDE_MIN_SIZE and self.alive and
                self.soul_weight > 0.2)

    def divide(self, field, next_id):
        cells_list = list(self.cells)
        xs = [c[0] for c in cells_list]
        median_x = np.median(xs)
        child1_cells = {c for c in cells_list if c[0] < median_x}
        child2_cells = {c for c in cells_list if c[0] >= median_x}
        if len(child1_cells) < 3 or len(child2_cells) < 3:
            return None
        self.cells = child1_cells
        child = Pattern(next_id, child2_cells, parent=self)
        noise = 0.02 * np.array([phi_hash(next_id, i, 200) - 0.5 for i in range(5)])
        child.belief = self.belief + noise
        child.unknown_belief = self.unknown_belief + 0.02 * (phi_hash(next_id, 99, 200) - 0.5)
        child.self_model = self.self_model + 0.02 * (np.array([phi_hash(next_id, 201, 200) - 0.5,
                                                                phi_hash(next_id, 202, 200) - 0.5]))
        child.update_properties(field)
        child.update_model(field)
        self.update_properties(field)
        self.update_model(field)
        return child

    def compete(self, other, field, current_phase="MODEL"):
        overlap = self.cells & other.cells
        if not overlap: return
        my_power = self.fitness * max(self.energy, 0)
        other_power = other.fitness * max(other.energy, 0)

        avg_unk = safe_mean(field[:,:,CH['unknown']], 0.05)
        if self.role == 1:
            my_power *= 1.0 + avg_unk
        else:
            bonus = 1.0 + max(0, (0.2 - avg_unk)) * 0.8
            if current_phase == "MODEL":
                bonus *= 1.1
            my_power *= bonus
        if other.role == 1:
            other_power *= 1.0 + avg_unk
        else:
            bonus = 1.0 + max(0, (0.2 - avg_unk)) * 0.8
            if current_phase == "MODEL":
                bonus *= 1.1
            other_power *= bonus

        if not np.isfinite(my_power):
            my_power = 0
        if not np.isfinite(other_power):
            other_power = 0

        winner, loser = (self, other) if my_power > other_power else (other, self)
        for cell in overlap.copy():
            if phi_hash(cell[0], cell[1], self.id) < 0.5:
                loser.cells.discard(cell)
                winner.cells.add(cell)
                field[cell[0], cell[1], CH['owner']] = winner.id
                winner.soul_weight += 0.01
                loser.soul_weight -= 0.02
            elif (loser.unresolved_contradiction > 0.2 and phi_hash(cell[0], cell[1], self.id + 999) < 0.2) or \
                 phi_hash(cell[0], cell[1], self.id + 777) < 0.05:
                winner.cells.discard(cell)
                loser.cells.add(cell)
                field[cell[0], cell[1], CH['owner']] = loser.id
                winner.soul_weight -= 0.01
                loser.soul_weight += 0.03

    def should_die(self):
        if self.soul_weight < 0.1:
            return True
        if self.unresolved_contradiction < 0.01:
            return True
        if self.given_trigger and phi_hash(self.id, self.age) < 0.15:
            return False
        if self.pred_error > PRED_ERROR_THRESHOLD:
            if self.coherence > 0.8 and phi_hash(self.id, self.age) < 0.3:
                return False
            return phi_hash(self.id, self.age) < 0.3
        if len(self.cells) < 2 and self.age > 5:
            return True
        if self.age > 120 and self.energy < 0.05:
            return True
        return False

