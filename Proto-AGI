def detect_bifurcation(field, patterns, prev_unknown, prev_tension, prev_belief_div, cooldown, boredom_score=0.0):
    if cooldown > 0:
        return np.zeros((WORLD_SIZE, WORLD_SIZE), dtype=bool), False, 0, 0, prev_unknown, prev_tension, prev_belief_div, 1.0, False

    tension_low = PHASE_TENSION_THRESHOLD_LOW_BASE * (1.0 - boredom_score * 0.8)
    tension_mid = PHASE_TENSION_THRESHOLD_MID_BASE * (1.0 - boredom_score * 0.8)
    tension_high = PHASE_TENSION_THRESHOLD_HIGH_BASE * (1.0 - boredom_score * 0.8)
    unknown_delta = PHASE_UNKNOWN_DELTA_THRESHOLD * (1.0 - boredom_score * 0.5)

    current_unknown = safe_mean(field[:,:,CH['unknown']], 0.05)
    delta_unknown = current_unknown - prev_unknown

    avg_tension = safe_mean([p.cognitive_tension for p in patterns], 0.1) if patterns else 0.0
    avg_belief_div = safe_std([np.mean(p.belief) for p in patterns], 0.1) if len(patterns) > 1 else 0.0

    crisis_level = 0
    if avg_tension > tension_low:
        crisis_level = 1
    if avg_tension > tension_mid or abs(delta_unknown) > unknown_delta:
        crisis_level = 2
    if avg_tension > tension_high and abs(delta_unknown) > unknown_delta:
        crisis_level = 3

    phase_event_mask = np.zeros((WORLD_SIZE, WORLD_SIZE), dtype=bool)
    global_event = (crisis_level >= 2)
    bifurcation_type = crisis_level
    global_hunger = 1.0
    recovery_needed = (crisis_level >= 1)

    if crisis_level >= 2:
        high_unknown = field[:,:,CH['unknown']] > safe_mean(field[:,:,CH['unknown']], 0.05) + safe_std(field[:,:,CH['unknown']], 0.01)
        phase_event_mask = high_unknown
        field[:,:,CH['energy']] += phase_event_mask * 0.03 * crisis_level
        field[:,:,CH['unknown']] += phase_event_mask * 0.1 * crisis_level
        field[:,:,CH['vorticity']] += phase_event_mask * 0.01 * crisis_level
        field[:,:,CH['crisis']] += phase_event_mask * 0.2 * crisis_level
        field[:,:,CH['binding']] += phase_event_mask * 0.15 * crisis_level
        for p in patterns:
            if any(phase_event_mask[x, y] for (x, y) in p.cells):
                p.model *= (0.9 - 0.05 * crisis_level)
                p.self_model *= (0.9 - 0.05 * crisis_level)
                p.pred_error += 0.05 * crisis_level
                p.crisis_memory = min(p.crisis_memory + 0.1 * crisis_level, CRISIS_MEMORY_MAX)
                p.given_cooldown = max(0, p.given_cooldown - 5)

    if len(patterns) > OVERPOPULATION_THRESHOLD:
        global_hunger = HUNGER_MULTIPLIER
        crisis_level = max(crisis_level, 1)
        recovery_needed = True

    return phase_event_mask, global_event, bifurcation_type, crisis_level, current_unknown, avg_tension, avg_belief_div, global_hunger, recovery_needed

def calculate_boredom(patterns, field):
    if len(patterns) == 0:
        return 0.5
    avg_err = safe_mean([p.pred_error for p in patterns], MIN_ACTIVE)
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.05)
    avg_tension = safe_mean([p.cognitive_tension for p in patterns], MIN_ACTIVE)
    avg_err = max(avg_err, MIN_ACTIVE)
    avg_tension = max(avg_tension, MIN_ACTIVE)
    boredom = 1.0 - (squash(avg_err) + squash(avg_tension) + squash(avg_unknown)) / 3.0
    return np.clip(boredom, 0.0, 1.0)

def compute_energy_gradient(field, x, y):
    xm = (x-1) % WORLD_SIZE; xp = (x+1) % WORLD_SIZE
    ym = (y-1) % WORLD_SIZE; yp = (y+1) % WORLD_SIZE
    dx = field[xp, y, CH['energy']] - field[xm, y, CH['energy']]
    dy = field[x, yp, CH['energy']] - field[x, ym, CH['energy']]
    return np.array([dx, dy])

def project(field, pos):
    x, y = pos
    x = min(max(x, 0), WORLD_SIZE-1); y = min(max(y, 0), WORLD_SIZE-1)
    return field[x, y]

def synchronous_agent_step(agents, field, t, target_energy):
    new_field = np.copy(field)
    for agent in agents:
        x, y = agent["pos"]
        perception = project(field, (x, y))
        agent["memory"] = 0.9 * agent["memory"]
        agent["memory"][:4] += perception[:4]
        grad = compute_energy_gradient(field, x, y)
        vort = field[x, y, CH['vorticity']]
        dx, dy = agent["drift"]
        dx += (perception[CH['energy']] - target_energy) * 0.05
        dx += grad[0] * GRADIENT_SENSITIVITY
        dx += vort * VORTICITY_COUPLING
        dy += (perception[CH['flux']] - 0.5) * 0.05
        dy += grad[1] * GRADIENT_SENSITIVITY
        dy -= vort * VORTICITY_COUPLING
        agent["drift"] = np.array([dx, dy]) * 0.95
        new_x = int((x + int(np.sign(dx))) % WORLD_SIZE)
        new_y = int((y + int(np.sign(dy))) % WORLD_SIZE)
        agent["pos"] = np.array([new_x, new_y])
        new_field[new_x, new_y, CH['energy']] += AGENT_INFLUENCE
        new_field[x, y, CH['flux']] += 0.001
        new_field[x, y, CH['vorticity']] += 0.001 * (dx - dy)
    return agents, new_field

def detect_invariants(field):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    mean = np.mean(energy)
    std = np.std(energy)
    if std == 0: return 0.0
    high = energy > mean + std
    return np.sum(high) / (WORLD_SIZE * WORLD_SIZE)

def reinforce_invariants(field, inv_score):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    mask = energy > np.mean(energy)
    field[:,:,CH['energy']] += (mask - 0.5) * inv_score * INVARIANT_REINFORCE
    return field

